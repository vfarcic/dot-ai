{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "dot-ai"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "dot-ai skills generate --agent claude-code",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/prd-done-changelog-reminder.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
